# Copy to `.env` for local dev (running Postgres on your host)
DATABASE_URL=postgresql+asyncpg://uniapi:uniapi@localhost:5432/uniapi

# If you run via `docker compose up -d`, the API container should use:
# DATABASE_URL=postgresql+asyncpg://uniapi:uniapi@postgres:5432/uniapi
APP_ENV=dev
APP_NAME=Uni API Backend
API_PREFIX=/v1
SESSION_TTL_DAYS=7
LLM_UPSTREAM_TIMEOUT_SECONDS=300

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# Demo data (optional)
SEED_DEMO_DATA=false

# Resend Email (verification codes)
RESEND_API_KEY=
RESEND_FROM_EMAIL=Uni API <onboarding@resend.dev>
EMAIL_VERIFICATION_REQUIRED=true
EMAIL_VERIFICATION_TTL_MINUTES=10

# Billing
# Card checkout via Creem (settled in USD)
CREEM_API_KEY=
CREEM_PRODUCT_ID=
CREEM_WEBHOOK_SECRET=

# Alipay / WeChat Pay via ZhuPay V2 (settled in CNY)
ZHUPAY_PID=
# PEM-formatted keys. If you keep them on a single line in env files, replace line breaks with \n.
ZHUPAY_PRIVATE_KEY=
ZHUPAY_PUBLIC_KEY=
ZHUPAY_API_BASE_URL=https://pay.lxsd.cn
# Price charged in CNY for each 1 USD credit when using ZhuPay.
ZHUPAY_CNY_PER_CREDIT=
# Public console URL used for Creem return_url and ZhuPay notify_url / return_url.
APP_PUBLIC_URL=http://localhost:3000

# Admin bootstrap (optional)
# - First registered user becomes owner automatically (empty DB).
# - For later users, set a strong token here and call `POST /v1/auth/admin/claim`.
ADMIN_BOOTSTRAP_TOKEN=
